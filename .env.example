# ─────────────────────────────────────────────────────────
# ARES Project — Environment Variables
# Copy this to .env and fill in your actual Neon DB URLs
# ─────────────────────────────────────────────────────────

# Your existing Neon PostgreSQL URLs
USER_DB_URL=postgresql://user:password@your-neon-host/ecommerce_users
PRODUCT_DB_URL=postgresql://user:password@your-neon-host/ecommerce_products
CART_DB_URL=postgresql://user:password@your-neon-host/ecommerce_cart
ORDER_DB_URL=postgresql://user:password@your-neon-host/ecommerce_orders

# Your existing JWT secret
JWT_SECRET=your_jwt_secret_here

# ─────────────────────────────────────────────────────────
# For the Next.js dashboard to talk to ARES API
# When running locally: http://localhost:8000
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ARES_API_URL=http://localhost:8000
